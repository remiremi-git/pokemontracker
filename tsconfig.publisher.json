{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "CommonJS",
    "moduleResolution": "Node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": ".dist/publisher",
    "rootDir": "."
  },
  "include": ["scripts/**/*.ts", "packages/notion-sync/src/**/*.ts"]
}
